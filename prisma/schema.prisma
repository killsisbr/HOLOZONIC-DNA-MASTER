generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "sqlite"
  url      = "file:D:/VENDA/HOLOZONIC/prisma/prod.db"
}

model User {
  id           Int     @id @default(autoincrement())
  user         String  @unique
  hash         String
  role         String  // ADMIN, MEDICO, RECP
  googleId     String? @unique
  refreshToken String?
}

model Patient {
  id           Int                @id @default(autoincrement())
  name         String
  cpf          String             @unique
  birthDate    String
  plan         String
  medications  String?            // Semicolon separated medicines
  active       Boolean            @default(true)
  appointments Appointment[]
  records      ClinicalRecord[]
}

model Appointment {
  id            Int      @id @default(autoincrement())
  patientId     Int
  patient       Patient  @relation(fields: [patientId], references: [id])
  dateTime      String
  type          String   // PRESENCIAL, TELE
  status        String   // AGUARDANDO, EM_ATENDIMENTO, FINALIZADO, CANCELADO
  googleEventId String?
  meetLink      String?
}

model ClinicalRecord {
  id          Int      @id @default(autoincrement())
  patientId   Int
  patient     Patient  @relation(fields: [patientId], references: [id])
  date        String
  type        String
  description String
  cid10       String?
  attachments Attachment[]
}

model Attachment {
  id               Int            @id @default(autoincrement())
  clinicalRecordId Int
  record           ClinicalRecord @relation(fields: [clinicalRecordId], references: [id])
  fileName         String
  filePath         String
  fileType         String
  createdAt        DateTime       @default(now())
}

model AILog {
  id                Int      @id @default(autoincrement())
  timestamp         DateTime @default(now())
  input             String
  distilledPattern  String?
  confidence        Float?
}

model PotentialLead {
  id        Int      @id @default(autoincrement())
  name      String?
  phone     String?
  email     String?
  source    String?  // INEZ, SONO, HOSPEDAGEM
  step      Int?
  data      String?  // JSON stringified object
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
